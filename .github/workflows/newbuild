name: Build PadavanOnly 360T7 (Official Method)

on:
  workflow_dispatch:

jobs:
  build:
    runs-on: ubuntu-22.04
    timeout-minutes: 240                    # ✅ 4 ساعات
    strategy:
      fail-fast: false                      # ✅ لا تتوقف عند خطأ

    steps:
    - name: Checkout source code
      uses: actions/checkout@v4

    - name: Install build dependencies
      run: |
        sudo apt update
        sudo apt install -y build-essential clang flex bison g++ gawk \
        gcc-multilib g++-multilib gettext git libncurses-dev libssl-dev \
        python3-distutils rsync unzip zlib1g-dev file wget

    - name: Clone PadavanOnly repository
      run: |
        git clone -b mt798x-mt799x-6.6-mtwifi --single-branch --filter=blob:none https://github.com/padavanonly/immortalwrt-mt798x-24.10.git openwrt

    - name: Update feeds
      run: |
        cd openwrt
        ./scripts/feeds update -a
        ./scripts/feeds install -a

    - name: Copy base config for MT7981
      run: |
        cd openwrt
        if [ -f defconfig/mt7981-ax3000.config ]; then
          cp -f defconfig/mt7981-ax3000.config .config
        else
          echo "CONFIG_TARGET_mediatek=y" >> .config
          echo "CONFIG_TARGET_mediatek_mt7981=y" >> .config
          echo "CONFIG_TARGET_mediatek_mt7981_DEVICE_xiaomi_mi-router-360t7=y" >> .config
          echo "CONFIG_PACKAGE_luci-app-mtk=y" >> .config
          echo "CONFIG_MTK_MTWIFI=y" >> .config
        fi

    - name: Fix known issues
      run: |
        cd openwrt
        echo "# CONFIG_PACKAGE_kmod-ipt-offload is not set" >> .config
        echo "CONFIG_MTK_HNAT_PPE_THRESHOLD=30" >> .config

    - name: Cache ccache
      uses: actions/cache@v4
      with:
        path: openwrt/.ccache
        key: ccache-padavanonly-${{ github.run_id }}
        restore-keys: |
          ccache-padavanonly-

    - name: Download all sources
      run: |
        cd openwrt
        make defconfig
        make download -j8

    - name: Build firmware
      run: |
        cd openwrt
        make -j$(nproc) V=s

    - name: Upload firmware artifacts
      uses: actions/upload-artifact@v4
      with:
        name: padavanonly-360t7
        path: openwrt/bin/targets/mediatek/mt7981/
        retention-days: 7

  release:
    name: Create Release
    runs-on: ubuntu-22.04
    needs: build
    if: success() && !cancelled()
    permissions:
      contents: write
    
    steps:
    - name: Download all artifacts
      uses: actions/download-artifact@v4
      with:
        path: artifacts

    - name: Extract 360T7 files only
      run: |
        mkdir release_files
        find artifacts -type f \( -name "*360t7*" -o -name "*qihoo*" \) -exec cp {} release_files/ \;
        echo "✅ Files found for release:"
        ls -la release_files/ || echo "⚠️ No 360T7 files found"

    - name: Create Release
      uses: softprops/action-gh-release@v1
      with:
        name: PadavanOnly-360T7-Build-${{ github.run_number }}
        tag_name: padavanonly-${{ github.run_number }}
        files: release_files/*
        fail_on_unmatched_files: false      # ✅ لا تفشل إذا لم تجد ملفات
      env:
        GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
